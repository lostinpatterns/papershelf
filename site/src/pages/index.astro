<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>papershelf</title>
    <meta name="description" content="Repo-local semantic search for coding agents" />
  </head>
  <body>
    <main class="shell">
      <div class="pixel-blast" aria-hidden="true"></div>

      <section class="card" aria-labelledby="title">
        <p class="bibliography">Papershelf. 2026. “Repo-local semantic search for coding agents.” CLI / agent reference.</p>
        <h1 id="title">papershelf</h1>
        <p class="tagline">Repo-local semantic search for coding agents</p>

        <div class="panes" aria-label="Setup and agent session">
          <article class="terminal setup-terminal" aria-labelledby="setup-title">
            <div class="terminal-bar">
              <span class="catalog-id" aria-hidden="true">PS-01</span>
              <div class="terminal-heading">
                <span id="setup-title" class="terminal-title">repo setup</span>
                <span class="terminal-meta">Papershelf CLI · 2026 · install + index workflow</span>
              </div>
            </div>
            <div class="terminal-body">
              <p><span class="prompt">$</span> <code>npm install -g papershelf</code></p>
              <p><span class="prompt">$</span> <code>cd your-repo</code></p>
              <p><span class="prompt">$</span> <code>papershelf init</code></p>
              <p><span class="prompt">$</span> <code>cp path/to/*.md .papershelf/docs/</code></p>
              <p><span class="prompt">$</span> <code>papershelf index</code></p>
            </div>
          </article>

          <article class="terminal agent-terminal" aria-labelledby="agent-title">
            <div class="terminal-bar">
              <span class="catalog-id" aria-hidden="true">PS-02</span>
              <div class="terminal-heading">
                <span id="agent-title" class="terminal-title">agent session</span>
                <span class="terminal-meta">Agent Skill · 2026 · source-backed retrieval trace</span>
              </div>
            </div>
            <div class="terminal-body agent-body">
              <p><span class="agent-token">reads</span> <code>.agents/skills/papershelf/SKILL.md</code></p>
              <p><span class="agent-token">runs</span> <code>papershelf search "retry strategy" --json</code></p>
              <p><span class="agent-token">finds</span> <code>.papershelf/docs/design.md:40-58</code></p>
              <p><span class="agent-token">cites</span> source path, lines, exact quote</p>
            </div>
          </article>
        </div>

        <nav class="links" aria-label="Links">
          <a href="https://github.com/lostinpatterns/papershelf">GitHub</a>
          <a href="https://github.com/lostinpatterns/papershelf#readme">README</a>
        </nav>
      </section>
    </main>
  </body>
</html>

<style>
  @import url("https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Pixelify+Sans:wght@400;700&display=swap");

  :root {
    color-scheme: light;
    --paper: #faf7ef;
    --card-paper: #fffdf6;
    --catalog: #efe6d3;
    --ink: #1f2523;
    --gray: #efe8dc;
    --rule: #d8d0c2;
    --shadow: #d9cfbd;
    --terminal-bg: #151917;
    --terminal-text: #f3ecdc;
    --terminal-muted: #98a292;
    --terminal-green: #9fcca6;
    --terminal-blue: #9eb7d7;
    --display: "Pixelify Sans", "Courier New", monospace;
    --mono: "IBM Plex Mono", "Courier New", monospace;
    font-family: var(--mono);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
    margin: 0;
  }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--mono);
    overflow-x: hidden;
    text-rendering: geometricPrecision;
  }

  ::selection {
    background: var(--gray);
    color: var(--ink);
  }

  .shell {
    min-height: 100svh;
    padding: 20px;
    background: var(--paper);
  }

  .pixel-blast {
    display: none;
  }

  .card {
    position: relative;
    width: 100%;
    min-height: calc(100svh - 40px);
    padding: clamp(22px, 3vw, 56px);
    overflow: hidden;
    border: 1px solid var(--rule);
    background:
      linear-gradient(rgba(216, 208, 194, 0.24) 1px, transparent 1px) 0 0 / 100% 34px,
      var(--paper);
    box-shadow: 0 24px 70px rgba(31, 37, 35, 0.1), 10px 10px 0 var(--shadow);
    text-align: left;
  }

  .bibliography,
  .tagline,
  .links {
    margin: 0;
  }

  .bibliography {
    max-width: 680px;
    padding-left: 14px;
    border-left: 3px solid var(--ink);
    color: var(--ink);
    font-family: var(--mono);
    font-size: clamp(12px, 1.2vw, 14px);
    line-height: 1.5;
  }

  h1 {
    max-width: 8ch;
    margin: clamp(58px, 7vw, 112px) 0 0;
    color: var(--ink);
    font-family: var(--display);
    font-size: clamp(74px, 17vw, 220px);
    font-weight: 700;
    letter-spacing: -0.07em;
    line-height: 0.72;
  }

  .tagline {
    position: relative;
    display: inline-block;
    max-width: 760px;
    margin-top: clamp(26px, 3vw, 42px);
    padding: 10px 16px;
    border: 1px solid rgba(154, 134, 99, 0.42);
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.22), transparent 18%, transparent 82%, rgba(31, 37, 35, 0.04)),
      var(--catalog);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.34),
      0 2px 0 rgba(31, 37, 35, 0.06);
    color: var(--ink);
    font-family: var(--mono);
    font-size: clamp(15px, 2vw, 23px);
    font-weight: 400;
    line-height: 1.35;
    text-wrap: balance;
    transform: rotate(-0.2deg);
  }

  .tagline::before,
  .tagline::after {
    content: "";
    position: absolute;
    top: -1px;
    bottom: -1px;
    width: 10px;
    background: var(--catalog);
  }

  .tagline::before {
    left: -9px;
    clip-path: polygon(100% 0, 100% 100%, 0 93%, 42% 76%, 0 58%, 48% 40%, 0 17%);
  }

  .tagline::after {
    right: -9px;
    clip-path: polygon(0 0, 100% 8%, 56% 25%, 100% 44%, 48% 62%, 100% 84%, 0 100%);
  }

  .panes {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(18px, 3vw, 42px);
    width: min(100%, 1120px);
    margin-top: clamp(64px, 10vw, 132px);
    text-align: left;
  }

  .terminal {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--rule);
    border-radius: 2px;
    background: var(--card-paper);
    box-shadow: 0 14px 36px rgba(31, 37, 35, 0.08), 7px 7px 0 var(--shadow);
  }

  .agent-terminal {
    transform: translateY(34px);
  }

  .terminal-bar {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    min-height: 64px;
    border-bottom: 1px solid var(--rule);
    background: var(--catalog);
  }

  .catalog-id {
    display: grid;
    min-width: 82px;
    padding: 14px 12px;
    place-items: center;
    border-right: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .terminal-heading {
    min-width: 0;
    padding: 12px 16px 11px;
  }

  .terminal-title,
  .terminal-meta {
    display: block;
    min-width: 0;
    overflow: hidden;
    color: var(--ink);
    font-family: var(--mono);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .terminal-title {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .terminal-meta {
    margin-top: 5px;
    font-size: 12px;
    line-height: 1.35;
  }

  .terminal-body {
    min-height: 268px;
    padding: clamp(20px, 2.2vw, 32px);
    background: var(--terminal-bg);
    box-shadow: inset 0 0 0 1px rgba(243, 236, 220, 0.06);
    color: var(--terminal-text);
    font-family: var(--mono);
    font-size: clamp(13px, 1.2vw, 16px);
    line-height: 1.7;
  }

  .terminal-body p {
    margin: 0;
    overflow-wrap: anywhere;
  }

  .terminal-body p + p {
    margin-top: 8px;
  }

  .setup-terminal .terminal-body p {
    display: grid;
    grid-template-columns: 2ch minmax(0, 1fr);
    column-gap: 0.55ch;
  }

  .agent-body p {
    display: flex;
    gap: 0.8ch;
    align-items: baseline;
  }

  code {
    color: inherit;
    font: inherit;
  }

  .terminal-body code {
    color: var(--terminal-text);
  }

  .prompt {
    color: var(--terminal-green);
    user-select: none;
  }

  .agent-token {
    display: inline-block;
    min-width: 8ch;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--terminal-blue);
    font-weight: 600;
    text-align: left;
    text-transform: uppercase;
    box-shadow: none;
  }

  .agent-body p:last-child {
    color: var(--terminal-muted);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-start;
    padding-top: clamp(58px, 8vw, 104px);
  }

  a {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 16px;
    border: 1px solid var(--rule);
    border-radius: 2px;
    background: var(--card-paper);
    box-shadow: 4px 4px 0 var(--shadow);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition:
      background-color 120ms ease,
      color 120ms ease,
      transform 120ms ease,
      box-shadow 120ms ease;
  }

  .links a:first-child {
    background: var(--ink);
    color: var(--paper);
  }

  a:hover {
    box-shadow: 0 0 0 var(--ink);
    transform: translate(4px, 4px);
  }

  a:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 4px;
  }

  @media (min-width: 901px) {
    html,
    body {
      height: 100%;
      overflow: hidden;
    }

    .shell {
      height: 100svh;
      min-height: 0;
      overflow: hidden;
    }

    .card {
      display: flex;
      flex-direction: column;
      height: calc(100svh - 40px);
      min-height: 0;
      padding: clamp(22px, 2.6vw, 44px);
    }

    h1 {
      margin-top: clamp(28px, 5svh, 56px);
      font-size: clamp(74px, 14vw, 184px);
    }

    .tagline {
      margin-top: clamp(18px, 2.4svh, 28px);
    }

    .panes {
      margin-top: clamp(28px, 5svh, 56px);
    }

    .agent-terminal {
      transform: translateY(clamp(14px, 3svh, 28px));
    }

    .terminal-body {
      min-height: clamp(178px, 23svh, 236px);
      padding: clamp(18px, 2vw, 26px);
    }

    .links {
      margin-top: auto;
      padding-top: clamp(18px, 3svh, 32px);
    }
  }

  @media (min-width: 901px) and (max-height: 800px) {
    .card {
      padding-block: 24px;
    }

    h1 {
      margin-top: 20px;
      font-size: clamp(66px, 12vw, 150px);
    }

    .bibliography {
      font-size: 12px;
      line-height: 1.35;
    }

    .tagline {
      margin-top: 14px;
      padding: 8px 12px;
      font-size: clamp(14px, 1.7vw, 18px);
    }

    .panes {
      margin-top: 24px;
    }

    .agent-terminal {
      transform: translateY(16px);
    }

    .terminal-bar {
      min-height: 56px;
    }

    .terminal-body {
      min-height: 150px;
      padding: 16px 20px;
      line-height: 1.55;
    }

    .terminal-body p + p {
      margin-top: 4px;
    }

    .links {
      padding-top: 12px;
    }

    a {
      min-height: 42px;
    }
  }

  @media (max-width: 900px) {
    .panes {
      grid-template-columns: 1fr;
      margin-top: 56px;
    }

    .agent-terminal {
      transform: none;
    }

    .terminal-body {
      min-height: 0;
    }
  }

  @media (max-width: 640px) {
    .shell {
      padding: 10px;
    }

    .card {
      min-height: calc(100svh - 20px);
      box-shadow: none;
    }

    h1 {
      max-width: 100%;
      margin-top: 28px;
      font-size: clamp(44px, 14vw, 72px);
      line-height: 0.86;
    }

    .tagline {
      margin-top: 22px;
    }

    .terminal-bar {
      min-height: 56px;
    }

    .catalog-id {
      min-width: 68px;
      padding: 12px 8px;
      font-size: 11px;
    }

    .terminal-heading {
      padding: 10px 12px;
    }

    .terminal-title {
      font-size: 12px;
    }

    .terminal-meta {
      font-size: 11px;
    }

    .terminal-body {
      font-size: 12px;
      line-height: 1.65;
    }

    .links {
      padding-top: 42px;
    }
  }

  @media (max-width: 420px) {
    .agent-body p {
      display: block;
    }

    .agent-token {
      margin: 0 0 4px;
    }

    .links a {
      width: 100%;
    }
  }
</style>
